# ─────────────────────────────────────────────────────────────────────
# SecurityBlogs CMS — environment variables
# Copy this file to .env (gitignored) and fill in real values.
# Every variable is required unless marked OPTIONAL.
# ─────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3001
# Externally-visible URL of THIS CMS. Used in admin links + emails.
NEXT_PUBLIC_SERVER_URL=http://localhost:3001
# Externally-visible URL of the public marketing site (Phase C onwards).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth — generate a long random string for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
PAYLOAD_SECRET=replace-me-with-48-random-bytes-in-hex

# Database — Postgres connection string. The docker-compose.yml spins up
# a local postgres at db:5432 with these defaults for development.
DATABASE_URI=postgres://securityblogs:securityblogs@db:5432/securityblogs

# Email — Hostinger SMTP (reuse your existing info@securityblogs.com.au mailbox).
# Port 465 with SMTPS (implicit TLS) is the recommended Hostinger config.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@securityblogs.com.au
SMTP_PASSWORD=replace-me-with-mailbox-password
EMAIL_FROM_NAME=SecurityBlogs
EMAIL_FROM_ADDRESS=info@securityblogs.com.au

# First Super Admin (used by the seed script on an empty DB).
# Change SEED_ADMIN_PASSWORD on first login.
SEED_ADMIN_EMAIL=yousif@securityblogs.com.au
SEED_ADMIN_NAME=Yousif Jonaid
SEED_ADMIN_PASSWORD=ChangeMeOnFirstLogin!2026

# Media storage — local disk by default. Future S3 swap-in via these vars.
MEDIA_LOCAL_PATH=./media-uploads
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:3001/media

# OPTIONAL — Cloudflare Turnstile (anti-bot) for the public /api/submit endpoint.
# Free at https://dash.cloudflare.com/?to=/:account/turnstile. Leave blank to disable.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# OPTIONAL — Plausible analytics dashboard URL (Phase D).
# Self-host docs: https://plausible.io/docs/self-hosting
PLAUSIBLE_DASHBOARD_URL=
