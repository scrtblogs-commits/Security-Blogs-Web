# ─────────────────────────────────────────────────────────────────────
# Public — exposed to the browser bundle. Both Maps tokens are
# referrer-restricted in their respective consoles so shipping them in
# the client is safe.
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_GMAPS_KEY=

# Canonical site URL — used for absolute links in sitemap, llms.txt and
# OpenGraph tags. Override per environment (staging URL during Phase C).
NEXT_PUBLIC_SITE_URL=https://securityblogs.com.au

# Cloudflare Turnstile (public site-key). Server-side secret lives in
# TURNSTILE_SECRET_KEY below.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─────────────────────────────────────────────────────────────────────
# Server-only — never exposed to the browser. Keep these out of git.
# ─────────────────────────────────────────────────────────────────────

# Payload CMS base URL. The marketing site fetches from this host on
# every ISR revalidation. In local dev this is the cms/ Next.js app on
# port 3001. In Phase D it becomes the internal Docker network name.
CMS_URL=http://localhost:3001

# Payload server-to-server API key. Generate one in Payload admin →
# Users → (your service account) → API Key. Used by /api/leads to
# create Lead documents without going through a user login.
PAYLOAD_API_KEY=

# Turnstile server secret. Used by /api/leads to verify the token the
# browser submits with the form.
TURNSTILE_SECRET_KEY=

# Resolver for inbound webhooks (Stripe in future phases, etc.). Keep
# unset until needed.
WEBHOOK_SECRET=

# ── Admin Panel ──────────────────────────────────────────────────────────────
# Login credentials for /admin. Set a strong password before going live.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_password_here

# ── Form Email Notifications ─────────────────────────────────────────────────
# Register free at https://web3forms.com → copy your Access Key.
# Without this, submissions are saved locally but no email is sent.
WEB3FORMS_KEY=
